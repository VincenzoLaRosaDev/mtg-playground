generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SyncSource {
  SCRYFALL
  MTGJSON
}

enum SyncStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum OracleTagWeight {
  very_strong
  strong
  median
  weak
}

enum ClassificationSource {
  OVERRIDE
  ORACLE_TAG
}

model Card {
  id              String   @id
  oracleId        String   @unique @map("oracle_id")
  name            String
  searchName      String   @map("search_name")
  slug            String?  @map("slug")
  typeLine        String   @map("type_line")
  cmc             Float
  manaCost        String?  @map("mana_cost")
  colors          String[]
  colorIdentity   String[] @map("color_identity")
  oracleText      String?  @map("oracle_text") @db.Text
  keywords        String[]
  producedMana    String[] @map("produced_mana")
  layout          String
  imageUri        String?  @map("image_uri")
  faces           Json?
  legalities      Json
  prices          Json?
  power           String?
  toughness       String?
  loyalty         String?
  popularityRank  Int?     @map("popularity_rank")
  isGameChanger   Boolean  @default(false) @map("is_game_changer")
  isReserved      Boolean  @default(false) @map("is_reserved")
  frictionScore   Int      @default(0) @map("friction_score")
  isCommander     Boolean  @default(false) @map("is_commander")
  /** Arena/Scryfall color order key — see `computeColorSortKey`. */
  colorSort       Int      @default(0) @map("color_sort")
  /** EUR-first catalog list price (USD fallback) — denormalized for SQL ORDER BY. */
  listPriceEur    Float?   @map("list_price_eur")
  /** Lowest printing rarity tier for this oracle (common…bonus). */
  minRarity       String?  @map("min_rarity")
  /** Numeric rank of minRarity — see RARITY_RANK. */
  minRarityRank   Int?     @map("min_rarity_rank")
  /**
   * Oracle/face text corpus for FTS weight C.
   * `search_tsv` is a DB-generated column (not mapped) — see migration.
   * Apostrophes are stripped in the generated expression so index matches query sanitize.
   */
  searchDocument  String   @default("") @map("search_document") @db.Text
  syncedAt        DateTime @default(now()) @map("synced_at")

  @@index([searchName])
  @@index([name])
  @@index([isCommander])
  @@index([slug])
  @@index([cmc])
  @@index([layout])
  @@index([popularityRank])
  @@index([isGameChanger])
  @@index([isReserved])
  @@index([frictionScore])
  @@index([colorSort])
  @@index([listPriceEur])
  @@index([minRarityRank])
  @@map("cards")
}

model MtgSet {
  code       String    @id
  scryfallId String    @unique @map("scryfall_id")
  name       String
  releasedAt DateTime? @map("released_at")
  setType    String    @map("set_type")
  cardCount  Int       @map("card_count")
  iconUri    String?   @map("icon_uri")
  digital    Boolean   @default(false)
  syncedAt   DateTime  @default(now()) @map("synced_at")

  printings Printing[]

  @@index([releasedAt])
  @@index([name])
  @@index([setType])
  @@map("mtg_sets")
}

/// One Scryfall printing (set + collector number). Soft-joins to cards via oracleId.
model Printing {
  id              String    @id
  oracleId        String    @map("oracle_id")
  setCode         String    @map("set_code")
  collectorNumber String    @map("collector_number")
  name            String
  rarity          String
  layout          String
  lang            String    @default("en")
  digital         Boolean   @default(false)
  finishes        String[]
  imageUri        String?   @map("image_uri")
  faces           Json?
  prices          Json?
  illustrationId  String?   @map("illustration_id")
  releasedAt      DateTime? @map("released_at")
  syncedAt        DateTime  @default(now()) @map("synced_at")

  set             MtgSet           @relation(fields: [setCode], references: [code], onDelete: Cascade)
  collectionItems CollectionItem[]

  @@unique([setCode, collectorNumber])
  @@index([oracleId])
  @@index([setCode])
  @@index([rarity])
  @@index([oracleId, releasedAt(sort: Desc)])
  @@map("printings")
}

// --- Auth.js (NextAuth v5) + collection ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  accounts        Account[]
  sessions        Session[]
  collectionItems CollectionItem[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// Personal collection row — printing + finish grain (Phase 2.1).
model CollectionItem {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  printingId String   @map("printing_id")
  /** nonfoil | foil | etched — must be available on the printing. */
  finish     String
  /**
   * Owned row (`wantlist=false`): copies in hand.
   * Wish row (`wantlist=true`): copies desired.
   * Always ≥ 1; qty 0 deletes the row. Owned and wish are separate rows.
   */
  quantity   Int      @default(1)
  wantlist   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  printing Printing @relation(fields: [printingId], references: [id], onDelete: Cascade)

  @@unique([userId, printingId, finish, wantlist])
  @@index([userId])
  @@index([printingId])
  @@index([userId, wantlist])
  @@map("collection_items")
}

model SyncLog {
  id               String     @id @default(cuid())
  source           SyncSource
  jobType          String     @map("job_type")
  status           SyncStatus
  startedAt        DateTime   @default(now()) @map("started_at")
  completedAt      DateTime?  @map("completed_at")
  recordsProcessed Int?       @map("records_processed")
  errors           Json?

  /// Health / recent-run lookups: filter source + jobType, order by startedAt
  @@index([source, jobType, startedAt])
  /// --if-changed / last-success lookups: filter source + jobType + status, order by completedAt
  @@index([source, jobType, status, completedAt])
  @@map("sync_logs")
}

model ScryfallOracleTag {
  id        String   @id
  slug      String   @unique
  label     String
  parentIds String[] @default([]) @map("parent_ids")
  syncedAt  DateTime @default(now()) @map("synced_at")

  taggings CardOracleTagging[]

  @@map("scryfall_oracle_tags")
}

model CardOracleTagging {
  id       String          @id @default(cuid())
  oracleId String          @map("oracle_id")
  tagId    String          @map("tag_id")
  weight   OracleTagWeight

  tag ScryfallOracleTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([oracleId, tagId])
  @@index([tagId])
  @@map("card_oracle_taggings")
}

model CardClassification {
  oracleId   String               @id @map("oracle_id")
  roles      String[]
  themes     String[]
  source     ClassificationSource
  tagSlugs   String[]             @default([]) @map("tag_slugs")
  computedAt DateTime             @default(now()) @map("computed_at")

  @@map("card_classifications")
}
