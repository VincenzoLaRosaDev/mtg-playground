generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SyncSource {
  SCRYFALL
  EDHREC
  MTGJSON
}

enum SyncStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum EdhrecSyncTier {
  HOT
  WARM
  COLD
}

enum EdhrecTopEntityType {
  CARD
  COMMANDER
}

enum EdhrecTopWindow {
  WEEK
  MONTH
  YEAR
  ALL
}

enum EdhrecPageEntityType {
  CARD
  COMMANDER
}

enum OracleTagWeight {
  very_strong
  strong
  median
  weak
}

enum ClassificationSource {
  OVERRIDE
  ORACLE_TAG
}

model Card {
  id            String   @id
  oracleId      String   @unique @map("oracle_id")
  name          String
  searchName    String   @map("search_name")
  edhrecSlug    String?  @map("edhrec_slug")
  typeLine      String   @map("type_line")
  cmc           Float
  colors        String[]
  colorIdentity String[] @map("color_identity")
  oracleText    String?  @map("oracle_text") @db.Text
  keywords      String[]
  producedMana  String[] @map("produced_mana")
  layout        String
  imageUri      String?  @map("image_uri")
  legalities    Json
  prices        Json?
  isCommander   Boolean  @default(false) @map("is_commander")
  syncedAt      DateTime @default(now()) @map("synced_at")

  edhrecCommanderProfile EdhrecCommanderProfile?
  edhrecCardData         EdhrecCardData?

  @@index([searchName])
  @@index([name])
  @@index([isCommander])
  @@index([edhrecSlug])
  @@index([cmc])
  @@index([layout])
  @@map("cards")
}

model EdhrecCommanderProfile {
  id            String         @id @default(cuid())
  slug          String         @unique
  name          String
  cardId        String?        @unique @map("card_id")
  rank          Int?
  salt          Float?
  numDecks      Int?           @map("num_decks")
  colorIdentity String[]       @map("color_identity")
  tagCounts     Json           @default("{}") @map("tag_counts")
  similarSlugs  String[]       @default([]) @map("similar_slugs")
  cardlists     Json           @default("{}")
  bracketCounts Json?          @map("bracket_counts")
  budgetCounts  Json?          @map("budget_counts")
  syncTier      EdhrecSyncTier @default(HOT) @map("sync_tier")
  syncedAt      DateTime       @default(now()) @map("synced_at")
  expiresAt     DateTime?      @map("expires_at")

  card Card? @relation(fields: [cardId], references: [id])

  @@index([rank])
  @@index([name])
  @@index([syncTier])
  @@index([numDecks])
  @@index([salt])
  @@index([expiresAt])
  @@map("edhrec_commander_profiles")
}

model EdhrecCardData {
  id           String         @id @default(cuid())
  slug         String         @unique
  name         String
  cardId       String?        @unique @map("card_id")
  salt         Float?
  numDecks     Int?           @map("num_decks")
  inclusion    Int?
  potentialDecks Int?         @map("potential_decks")
  cardlists    Json           @default("{}")
  similarCards Json           @default("[]") @map("similar_cards")
  syncTier     EdhrecSyncTier @default(HOT) @map("sync_tier")
  syncedAt     DateTime       @default(now()) @map("synced_at")
  expiresAt    DateTime?      @map("expires_at")

  card Card? @relation(fields: [cardId], references: [id])

  @@index([name])
  @@index([syncTier])
  @@index([inclusion])
  @@index([numDecks])
  @@index([salt])
  @@index([expiresAt])
  @@map("edhrec_card_data")
}

model EdhrecTopEntry {
  id             String              @id @default(cuid())
  entityType     EdhrecTopEntityType @map("entity_type")
  window         EdhrecTopWindow
  rank           Int
  slug           String
  name           String
  numDecks       Int?                @map("num_decks")
  inclusion      Int?
  potentialDecks Int?                @map("potential_decks")
  syncedAt       DateTime            @default(now()) @map("synced_at")

  @@unique([entityType, window, slug])
  @@index([entityType, window, rank])
  @@index([slug])
  @@map("edhrec_top_entries")
}

model EdhrecPageVariant {
  id         String               @id @default(cuid())
  entityType EdhrecPageEntityType @map("entity_type")
  slug       String
  theme      String               @default("")
  budget     String               @default("")
  bracket    String               @default("")
  payload    Json
  syncedAt   DateTime             @default(now()) @map("synced_at")
  expiresAt  DateTime?            @map("expires_at")

  @@unique([entityType, slug, theme, budget, bracket])
  @@index([entityType, slug])
  @@index([expiresAt])
  @@map("edhrec_page_variants")
}

model MtgSet {
  code       String    @id
  scryfallId String    @unique @map("scryfall_id")
  name       String
  releasedAt DateTime? @map("released_at")
  setType    String    @map("set_type")
  cardCount  Int       @map("card_count")
  iconUri    String?   @map("icon_uri")
  digital    Boolean   @default(false)
  syncedAt   DateTime  @default(now()) @map("synced_at")

  setCards SetCard[]

  @@index([releasedAt])
  @@index([name])
  @@index([setType])
  @@map("mtg_sets")
}

model SetCard {
  id              String  @id @default(cuid())
  setCode         String  @map("set_code")
  oracleId        String  @map("oracle_id")
  name            String
  collectorNumber String  @map("collector_number")
  rarity          String
  imageUri        String? @map("image_uri")

  set MtgSet @relation(fields: [setCode], references: [code], onDelete: Cascade)

  @@unique([setCode, oracleId])
  @@index([setCode])
  @@index([oracleId])
  @@index([rarity])
  @@map("set_cards")
}

model SyncLog {
  id               String     @id @default(cuid())
  source           SyncSource
  jobType          String     @map("job_type")
  status           SyncStatus
  startedAt        DateTime   @default(now()) @map("started_at")
  completedAt      DateTime?  @map("completed_at")
  recordsProcessed Int?       @map("records_processed")
  errors           Json?

  /// Health / recent-run lookups: filter source + jobType, order by startedAt
  @@index([source, jobType, startedAt])
  /// --if-changed / last-success lookups: filter source + jobType + status, order by completedAt
  @@index([source, jobType, status, completedAt])
  @@map("sync_logs")
}

model ScryfallOracleTag {
  id        String   @id
  slug      String   @unique
  label     String
  parentIds String[] @default([]) @map("parent_ids")
  syncedAt  DateTime @default(now()) @map("synced_at")

  taggings CardOracleTagging[]

  @@map("scryfall_oracle_tags")
}

model CardOracleTagging {
  id       String          @id @default(cuid())
  oracleId String          @map("oracle_id")
  tagId    String          @map("tag_id")
  weight   OracleTagWeight

  tag ScryfallOracleTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([oracleId, tagId])
  @@index([oracleId])
  @@index([tagId])
  @@map("card_oracle_taggings")
}

model CardClassification {
  oracleId   String               @id @map("oracle_id")
  roles      String[]
  themes     String[]
  source     ClassificationSource
  tagSlugs   String[]             @default([]) @map("tag_slugs")
  computedAt DateTime             @default(now()) @map("computed_at")

  @@map("card_classifications")
}
