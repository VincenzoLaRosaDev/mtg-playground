# Pooled connection — used by the app at runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=verify-full"

# Direct connection — used by Prisma migrations only
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=verify-full"

# Optional: canonical site URL for SEO (metadata, sitemap, robots)
# NEXT_PUBLIC_SITE_URL="https://mtgplayground.example.com"

# Auth.js (Phase 2.1) — generate with: openssl rand -base64 32
AUTH_SECRET=""

# OAuth (optional independently — omit a pair to disable that provider)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
# AUTH_DISCORD_ID=""
# AUTH_DISCORD_SECRET=""

# Magic link via Resend (optional — without AUTH_RESEND_KEY, email sign-in is disabled)
# AUTH_RESEND_KEY=""
# AUTH_RESEND_FROM="MTGPlayground <noreply@yourdomain.com>"

# GitHub Actions sync jobs use repository secret DATABASE_URL (Neon pooled).
# There is no app /api/sync endpoint — workflows run npm scripts directly.
